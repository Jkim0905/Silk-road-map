<!DOCTYPE html>
<html>
<head>
  <title>Silk Road Exchange Map</title>
  <meta name="viewport" content="width=device-width, initial-scale=1.0">

  <link rel="stylesheet" href="https://unpkg.com/leaflet/dist/leaflet.css"/>

  <style>
    body { font-family: sans-serif; margin: 0; }
    #controls {
      padding: 10px;
      background: white;
      position: absolute;
      z-index: 1000;
    }
    #map { height: 100vh; }
  </style>
</head>

<body>

<div id="controls">
  <input type="file" id="imageInput" />
  <button onclick="uploadData()">Add Object</button>
</div>

<div id="map"></div>

<script src="https://unpkg.com/leaflet/dist/leaflet.js"></script>
<script src="app.js"></script>

</body>
</html>
// create map
const map = L.map('map').setView([20, 0], 2);

// add map tiles
L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
  maxZoom: 18,
}).addTo(map);

let markers = [];
let lines = [];

// upload + place marker
function uploadData() {
  const file = document.getElementById("imageInput").files[0];

  if (!file) {
    alert("Please upload an image first!");
    return;
  }

  navigator.geolocation.getCurrentPosition((position) => {
    const lat = position.coords.latitude;
    const lng = position.coords.longitude;

    const imageURL = URL.createObjectURL(file);

    addMarker(lat, lng, imageURL);
  }, () => {
    alert("Location access denied!");
  });
}

// add marker
function addMarker(lat, lng, imageURL) {
  const marker = L.marker([lat, lng]).addTo(map);

  marker.bindPopup(`<img src="${imageURL}" width="150"/>`);

  markers.push([lat, lng]);

  drawConnections();
}

// draw lines between points
function drawConnections() {
  // remove old lines
  lines.forEach(line => map.removeLayer(line));
  lines = [];

  for (let i = 0; i < markers.length - 1; i++) {
    const line = L.polyline([markers[i], markers[i + 1]], {
      color: 'red',
      weight: 2,
      opacity: 0.6
    }).addTo(map);

    lines.push(line);
  }
}
